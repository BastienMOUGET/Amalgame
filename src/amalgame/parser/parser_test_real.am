namespace Amalgame.Compiler

import Amalgame.Collections
import Amalgame.IO
import Amalgame.String

public class Program {
    public static void Main(string[] args) {
        let src1 = File.ReadAll("./src/amalgame/lexer/token.am")
        let lex1  = new Lexer(src1, "token.am")
        let tok1  = lex1.Tokenize()
        let par1  = new Parser(tok1)
        let prg1  = par1.Parse()
        let dc1   = prg1.Children.Count()
        let err1  = par1.HasErrors()
        Console.WriteLine("token.am: decls={dc1} errors={err1}")

        let src2 = File.ReadAll("./src/amalgame/lexer/lexer.am")
        let lex2  = new Lexer(src2, "lexer.am")
        let tok2  = lex2.Tokenize()
        let par2  = new Parser(tok2)
        let prg2  = par2.Parse()
        let dc2   = prg2.Children.Count()
        let err2  = par2.HasErrors()
        Console.WriteLine("lexer.am: decls={dc2} errors={err2}")

        let src3 = File.ReadAll("./src/amalgame/parser/ast.am")
        let lex3  = new Lexer(src3, "ast.am")
        let tok3  = lex3.Tokenize()
        let par3  = new Parser(tok3)
        let prg3  = par3.Parse()
        let dc3   = prg3.Children.Count()
        let err3  = par3.HasErrors()
        Console.WriteLine("ast.am: decls={dc3} errors={err3}")

        let src4 = File.ReadAll("./src/amalgame/parser/parser.am")
        let lex4  = new Lexer(src4, "parser.am")
        let tok4  = lex4.Tokenize()
        let par4  = new Parser(tok4)
        let prg4  = par4.Parse()
        let dc4   = prg4.Children.Count()
        let err4  = par4.HasErrors()
        Console.WriteLine("parser.am: decls={dc4} errors={err4}")
    }
}

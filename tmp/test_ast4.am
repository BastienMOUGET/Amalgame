namespace Amalgame.Compiler

import Amalgame.Collections

public class Program {
    public static void Main(string[] args) {
        let prog = Ast.Program(0, 0)

        let cls = Ast.Class("Foo", 1, 1)
        prog.Children.Add(cls)
        Console.WriteLine("add ok")

        // Test Count directly on Children
        let ch = prog.Children
        Console.WriteLine("got ch")
        let c1 = ch.Count()
        Console.WriteLine("c1: {c1}")
    }
}

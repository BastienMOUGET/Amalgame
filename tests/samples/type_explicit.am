namespace Tests

public class Program {
    public static void Main(string[] args) {
        let x: int    = 42
        let y: float  = 3.14
        let s: string = "typed"
        let b: bool   = true

        Console.WriteLine("x: {x}")
        Console.WriteLine("s: {s}")
        Console.WriteLine("b: {b}")

        var count: int = 0
        count = count + 1
        count = count + 1
        Console.WriteLine("count: {count}")

        let big    = 1000000
        let result = big * 42
        Console.WriteLine("big: {result}")

        let pi   = 3.14159
        let r    = 2.0
        let area = pi * r * r
        let pos  = area > 0.0
        Console.WriteLine("area positive: {pos}")

        let neg = 0 - 42
        let abs = 0 - neg
        Console.WriteLine("neg: {neg}")
        Console.WriteLine("abs: {abs}")
    }
}
